   EFI_EVENT            PciIoEvent;
 
+  DEBUG ((DEBUG_ERROR, "%a: ENTRY (eve-trace)\n", __FUNCTION__));
+
   OpRegionStatus = QemuFwCfgFindFile (
                      ASSIGNED_IGD_FW_CFG_OPREGION,
                      &mOpRegionItem,
                      &mOpRegionSize
                      );
 
+  DEBUG ((DEBUG_ERROR, "%a: QemuFwCfgFindFile(%a)=%r mOpRegionSize=0x%Lx (eve-trace)\n",
+    __FUNCTION__, ASSIGNED_IGD_FW_CFG_OPREGION, OpRegionStatus, (UINT64)mOpRegionSize));
+
   //
   // If neither fw_cfg file is available, assume no IGD is assigned.
   //
   if (EFI_ERROR (OpRegionStatus)) {
+    DEBUG ((DEBUG_ERROR, "%a: returning EFI_UNSUPPORTED — no etc/igd-opregion in fw_cfg (eve-trace)\n",
+      __FUNCTION__));
     return EFI_UNSUPPORTED;
   }
 
