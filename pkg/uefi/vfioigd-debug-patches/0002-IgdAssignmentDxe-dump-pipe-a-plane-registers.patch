diff --git a/IgdAssignmentDxe/IgdRegisterDump.c b/IgdAssignmentDxe/IgdRegisterDump.c
new file mode 100644
index 0000000..0eae1b4
--- /dev/null
+++ b/IgdAssignmentDxe/IgdRegisterDump.c
@@ -0,0 +1,159 @@
+/** @file
+  Register-level diagnostic dump for the assigned Intel iGPU.
+
+  See IgdRegisterDump.h for context.
+
+  Copyright (c) 2026 Zededa, Inc.
+  SPDX-License-Identifier: BSD-2-Clause-Patent
+**/
+
+#include <Library/DebugLib.h>
+#include <Library/PrintLib.h>
+#include <Protocol/PciIo.h>
+
+#include "IgdRegisterDump.h"
+
+STATIC IGD_USED_RETAIN
+CONST CHAR8 *
+TileModeToString (
+  IN UINT32 RawTileBits
+  )
+{
+  switch (RawTileBits) {
+    case IgdTileLinear:  return "linear";
+    case IgdTileX:       return "X-tiled";
+    case IgdTileYLegacy: return "Y-tiled (gen11) / Tile4 (gen12+)";
+    case IgdTileYf:      return "Yf-tiled";
+    default:             return "?";
+  }
+}
+
+STATIC IGD_USED_RETAIN
+CONST CHAR8 *
+PlaneFormatToString (
+  IN UINT32 Format
+  )
+{
+  switch (Format) {
+    case IgdFmtYUV422:           return "YUV422";
+    case IgdFmtNV12:             return "NV12";
+    case IgdFmtRGB2101010:       return "RGB2101010";
+    case IgdFmtP010:             return "P010";
+    case IgdFmtRGB8888:          return "RGB8888";
+    case IgdFmtP012:             return "P012";
+    case IgdFmtRGB16161616F:     return "RGB16161616F";
+    case IgdFmtP016:             return "P016";
+    case IgdFmtRGB8888_NoAlpha:  return "RGB8888-NoAlpha";
+    case IgdFmtRGB565:           return "RGB565";
+    default:                     return "?";
+  }
+}
+
+/**
+  Read a single 32-bit register from BAR0 with diagnostic logging on
+  error.  Returns 0 and logs DEBUG_ERROR if the read fails — the caller
+  cannot distinguish read-failure from a genuine zero, but for the
+  intended use-case (a passive end-of-DXE diagnostic dump) that
+  ambiguity is acceptable: the read-failure log line will still surface
+  in efi-debug.log alongside whatever zero we end up printing.
+**/
+STATIC IGD_USED_RETAIN
+UINT32
+ReadBar0Reg32 (
+  IN EFI_PCI_IO_PROTOCOL *PciIo,
+  IN UINT32              Offset
+  )
+{
+  EFI_STATUS Status;
+  UINT32     Value = 0;
+
+  Status = PciIo->Mem.Read (
+                        PciIo,
+                        EfiPciIoWidthUint32,
+                        0,           // BarIndex 0 (GTTMMADR)
+                        Offset,
+                        1,           // Count
+                        &Value
+                        );
+  if (EFI_ERROR (Status)) {
+    DEBUG ((DEBUG_ERROR,
+      "%a: BAR0 MMIO read at offset 0x%05x failed: %r (eve-trace)\n",
+      __FUNCTION__, Offset, Status));
+    return 0;
+  }
+  return Value;
+}
+
+VOID
+EFIAPI
+IgdDumpPipeARegisters (
+  IN EFI_PCI_IO_PROTOCOL *PciIo
+  )
+{
+  UINT32 PlaneCtl;
+  UINT32 PlaneStride;
+  UINT32 PlanePos;
+  UINT32 PlaneSize;
+  UINT32 PlaneSurf;
+  UINT32 PlaneOffset;
+  UINT32 PipeConf;
+  UINT32 PipeSrcSz;
+  UINT32 TileMode;
+  UINT32 Format;
+  UINT32 SrcWidth;
+  UINT32 SrcHeight;
+
+  PlaneCtl    = ReadBar0Reg32 (PciIo, IGD_PLANE_CTL_1_A_OFFSET);
+  PlaneStride = ReadBar0Reg32 (PciIo, IGD_PLANE_STRIDE_1_A_OFFSET);
+  PlanePos    = ReadBar0Reg32 (PciIo, IGD_PLANE_POS_1_A_OFFSET);
+  PlaneSize   = ReadBar0Reg32 (PciIo, IGD_PLANE_SIZE_1_A_OFFSET);
+  PlaneSurf   = ReadBar0Reg32 (PciIo, IGD_PLANE_SURF_1_A_OFFSET);
+  PlaneOffset = ReadBar0Reg32 (PciIo, IGD_PLANE_OFFSET_1_A_OFFSET);
+  PipeConf    = ReadBar0Reg32 (PciIo, IGD_PIPE_A_CONF_OFFSET);
+  PipeSrcSz   = ReadBar0Reg32 (PciIo, IGD_PIPE_A_SRCSZ_OFFSET);
+
+  TileMode  = (PlaneCtl & IGD_PLANE_CTL_TILED_MASK)  >> IGD_PLANE_CTL_TILED_SHIFT;
+  Format    = (PlaneCtl & IGD_PLANE_CTL_FORMAT_MASK) >> IGD_PLANE_CTL_FORMAT_SHIFT;
+  SrcWidth  = ( PipeSrcSz        & 0x1FFF) + 1;  // [12:0]  width  - 1
+  SrcHeight = ((PipeSrcSz >> 16) & 0x1FFF) + 1;  // [28:16] height - 1
+
+  //
+  // One DEBUG_ERROR per line — keeps each register easy to grep / diff
+  // across two boots without joining wrapped output.
+  //
+  DEBUG ((DEBUG_ERROR,
+    "IgdDumpPipeARegisters: --- pipe A scanout state @ end-of-DXE (eve-trace) ---\n"));
+
+  DEBUG ((DEBUG_ERROR,
+    "  PLANE_CTL_1_A    = 0x%08x  enabled=%d tile=%a (raw=%d) "
+    "format=%a (raw=0x%x) async_flip=%d (eve-trace)\n",
+    PlaneCtl,
+    (PlaneCtl & IGD_PLANE_CTL_ENABLE) ? 1 : 0,
+    TileModeToString (TileMode),
+    TileMode,
+    PlaneFormatToString (Format),
+    Format,
+    (PlaneCtl & IGD_PLANE_CTL_ASYNC_FLIP) ? 1 : 0));
+
+  DEBUG ((DEBUG_ERROR,
+    "  PLANE_STRIDE_1_A = 0x%08x  (linear bytes, or tiles depending on tile mode) (eve-trace)\n",
+    PlaneStride));
+
+  DEBUG ((DEBUG_ERROR,
+    "  PLANE_SURF_1_A   = 0x%08x  (GTT offset of scanout buffer) (eve-trace)\n",
+    PlaneSurf));
+
+  DEBUG ((DEBUG_ERROR,
+    "  PLANE_SIZE_1_A   = 0x%08x  (%dx%d) (eve-trace)\n",
+    PlaneSize,
+    (PlaneSize & 0x1FFF) + 1,
+    ((PlaneSize >> 16) & 0x1FFF) + 1));
+
+  DEBUG ((DEBUG_ERROR,
+    "  PLANE_POS_1_A    = 0x%08x  PLANE_OFFSET_1_A = 0x%08x (eve-trace)\n",
+    PlanePos, PlaneOffset));
+
+  DEBUG ((DEBUG_ERROR,
+    "  PIPE_A_CONF      = 0x%08x  PIPE_A_SRCSZ = 0x%08x (%dx%d) (eve-trace)\n",
+    PipeConf, PipeSrcSz, SrcWidth, SrcHeight));
+}
diff --git a/IgdAssignmentDxe/IgdRegisterDump.h b/IgdAssignmentDxe/IgdRegisterDump.h
new file mode 100644
index 0000000..01d5bca
--- /dev/null
+++ b/IgdAssignmentDxe/IgdRegisterDump.h
@@ -0,0 +1,133 @@
+/** @file
+  Register-level diagnostic dump for the assigned Intel iGPU.
+
+  Reads a curated set of display-engine registers from the iGPU's BAR0
+  (GTTMMADR — combined GTT and MMIO) and prints them in a decoded form.
+  Intended to surface the state of pipe A scanout configuration at
+  end-of-DXE — i.e. before the OS's IGD driver binds and reprograms the
+  display engine.  Useful for triaging tile-mode mismatches between
+  what a producer wrote and what the display engine reads back.
+
+  Register offsets and bit layouts are taken from the Intel Open Source
+  HD Graphics Programmer's Reference Manual, Volume 2c, Display Engine
+  Registers.  The set covers gen11 — gen13 (Tiger Lake through Meteor
+  Lake); fields not present on older parts read as zero.
+
+  This is a passive dump: no register is written, no state is mutated.
+
+  Copyright (c) 2026 Zededa, Inc.
+  SPDX-License-Identifier: BSD-2-Clause-Patent
+**/
+
+#ifndef IGD_REGISTER_DUMP_H_
+#define IGD_REGISTER_DUMP_H_
+
+#include <Protocol/PciIo.h>
+
+//
+// IGD_USED_RETAIN — keep STATIC functions live across gcc LTO +
+// --gc-sections.  gcc-14 is aggressive enough that, without this,
+// helpers get stripped before their callers can reach them.  The
+// `retain` attribute exists from gcc 11.0, but gcc 11.x issues a
+// "retain attribute ignored" warning in some LTO contexts that
+// `-Werror=attributes` then escalates to a hard build error; gcc 12
+// cleaned that up.  Gate on __GNUC__ >= 12 so the current Alpine 3.16
+// build env (gcc 11.2) falls back to bare `used` while a future EVE
+// on Alpine 3.22 / gcc 14 gets the full attribute.
+//
+#if defined (__GNUC__) && (__GNUC__ >= 12)
+#define IGD_USED_RETAIN __attribute__ ((used, retain))
+#else
+#define IGD_USED_RETAIN __attribute__ ((used))
+#endif
+
+//
+// Display-engine register offsets, gen11+ (BAR0 / GTTMMADR MMIO).
+// Pipe A, Universal Plane 1.  See PRM Vol 2c.
+//
+#define IGD_PLANE_CTL_1_A_OFFSET        0x70180
+#define IGD_PLANE_STRIDE_1_A_OFFSET     0x70188
+#define IGD_PLANE_POS_1_A_OFFSET        0x7018C
+#define IGD_PLANE_SIZE_1_A_OFFSET       0x70190
+#define IGD_PLANE_KEYVAL_1_A_OFFSET     0x70194
+#define IGD_PLANE_KEYMSK_1_A_OFFSET     0x70198
+#define IGD_PLANE_SURF_1_A_OFFSET       0x7019C
+#define IGD_PLANE_KEYMAX_1_A_OFFSET     0x701A0
+#define IGD_PLANE_OFFSET_1_A_OFFSET     0x701A4
+#define IGD_PLANE_AUX_DIST_1_A_OFFSET   0x701C0
+#define IGD_PLANE_AUX_OFFSET_1_A_OFFSET 0x701C4
+
+//
+// Pipe configuration / source-size (transcoder A registers).
+//
+#define IGD_PIPE_A_CONF_OFFSET          0x70008
+#define IGD_PIPE_A_SRCSZ_OFFSET         0x6001C
+
+//
+// PLANE_CTL bit fields (gen11+).
+//
+#define IGD_PLANE_CTL_ENABLE                 BIT31
+#define IGD_PLANE_CTL_PIPE_GAMMA_DISABLE     BIT30
+#define IGD_PLANE_CTL_FORMAT_MASK            (0xF << 24)
+#define IGD_PLANE_CTL_FORMAT_SHIFT           24
+#define IGD_PLANE_CTL_PIPE_CSC_ENABLE        BIT23
+#define IGD_PLANE_CTL_KEY_ENABLE_MASK        (0x3 << 21)
+#define IGD_PLANE_CTL_KEY_ENABLE_SHIFT       21
+#define IGD_PLANE_CTL_RGB_ORDER_BGRX         BIT20
+#define IGD_PLANE_CTL_PIPE_CSC_ENABLE_GEN12  BIT17
+#define IGD_PLANE_CTL_RENDER_DECOMP_ENABLE   BIT15
+#define IGD_PLANE_CTL_TRICKLE_FEED_DISABLE   BIT14
+#define IGD_PLANE_CTL_PLANE_GAMMA_DISABLE    BIT13
+#define IGD_PLANE_CTL_TILED_MASK             (0x7 << 10)
+#define IGD_PLANE_CTL_TILED_SHIFT            10
+#define IGD_PLANE_CTL_ASYNC_FLIP             BIT9
+#define IGD_PLANE_CTL_ALPHA_MODE_MASK        (0x3 << 4)
+#define IGD_PLANE_CTL_ALPHA_MODE_SHIFT       4
+#define IGD_PLANE_CTL_ROTATE_MASK            (0x3 << 0)
+#define IGD_PLANE_CTL_ROTATE_SHIFT           0
+
+//
+// Tile-mode encoding in PLANE_CTL[12:10].  For gen12+ the meaning of
+// "Y-Tiled" was redefined as Tile4; older bits remain valid.
+//
+typedef enum {
+  IgdTileLinear     = 0x0,
+  IgdTileX          = 0x1,
+  IgdTileYLegacy    = 0x4,
+  IgdTileYf         = 0x5
+} IGD_TILE_MODE;
+
+//
+// Source pixel format encoding in PLANE_CTL[27:24].  Subset of values
+// most commonly seen on a desktop scanout.
+//
+typedef enum {
+  IgdFmtYUV422       = 0x0,
+  IgdFmtNV12         = 0x1,
+  IgdFmtRGB2101010   = 0x2,
+  IgdFmtP010         = 0x3,
+  IgdFmtRGB8888      = 0x4,
+  IgdFmtP012         = 0x5,
+  IgdFmtRGB16161616F = 0x6,
+  IgdFmtP016         = 0x7,
+  IgdFmtRGB565       = 0xE,
+  IgdFmtRGB8888_NoAlpha = 0xC
+} IGD_PLANE_FORMAT;
+
+/**
+  Read and pretty-print the pipe-A scanout-configuration registers from
+  the iGPU's BAR0 MMIO region.
+
+  Output goes through DEBUG_ERROR so it always surfaces regardless of
+  PCD debug-print level.  Each line carries the (eve-trace) marker for
+  grep-friendliness.
+
+  @param[in] PciIo  EFI_PCI_IO_PROTOCOL instance for the iGPU.
+**/
+VOID
+EFIAPI
+IgdDumpPipeARegisters (
+  IN EFI_PCI_IO_PROTOCOL *PciIo
+  );
+
+#endif // IGD_REGISTER_DUMP_H_
